import urllib.request
from tensorflow.keras.applications import InceptionV3
from tensorflow.keras import layers, models
from tensorflow.keras.optimizers import SGD

# Download the weights file
url = "https://storage.googleapis.com/mledu-datasets/inception_v3_weights_tf_dim_ordering_tf_kernels_notop.h5"
local_weights_file = "/tmp/inception_v3_weights_tf_dim_ordering_tf_kernels_notop.h5"

# Download weights
urllib.request.urlretrieve(url, local_weights_file)
print(f"Weights downloaded to {local_weights_file}")

# Load the InceptionV3 model without the top (final) layer
pre_trained_model = InceptionV3(input_shape=(150, 150, 3), include_top=False, weights=None)
pre_trained_model.load_weights(local_weights_file)

# Freeze all layers to prevent them from training
for layer in pre_trained_model.layers:
    layer.trainable = False

# Access the 'mixed7' layer
last_layer = pre_trained_model.get_layer('mixed7')
print('Last layer output shape:', last_layer.output.shape)

# Get the output of the 'mixed7' layer
last_output = last_layer.output

# Add custom layers on top of the pre-trained model
x = layers.Flatten()(last_output)
x = layers.Dense(1024, activation='relu')(x)
x = layers.Dropout(0.2)(x)
x = layers.Dense(1, activation='sigmoid')(x)  # For binary classification

# Create the final model
model = models.Model(inputs=pre_trained_model.input, outputs=x)

# Compile the model
model.compile(optimizer=SGD(learning_rate=0.001, momentum=0.9),
              loss='binary_crossentropy',
              metrics=['accuracy'])

# Summary of the model
model.summary()

# Flatten the output layer to 1 dimension
x = layers.Flatten()(last_output)

# Add a fully connected layer with 1,024 hidden units and ReLU activation
x = layers.Dense(1024, activation='relu')(x)

# Add a dropout rate of 0.5
x = layers.Dropout(0.5)(x)

# Add a final sigmoid layer for classification
x = layers.Dense(1, activation='sigmoid')(x)

unfreeze = False

# Unfreeze all models after "mixed6"
for layer in pre_trained_model.layers:
    if unfreeze:
        layer.trainable = True
    if layer.name == 'mixed6':
        unfreeze = True

# Configure the model
model = Model(pre_trained_model.input, x)

# Use the SGD optimizer with the correct 'learning_rate' parameter
model.compile(
    loss='binary_crossentropy',
    optimizer=SGD(
        learning_rate=0.00001,  # Correct parameter name
        momentum=0.9
    ),
    metrics=['acc']
)

model.summary()
