import os
from tensorflow.keras.preprocessing.image import ImageDataGenerator

# Mount Google Drive
drive.mount('/content/drive')

# Base dataset directory
base_dir = '/content/drive/MyDrive/Extracted_Zip/dataset'

# Subfolders (train/test split for multiple classes)
train_dirs = {
    'Car': os.path.join(base_dir, 'car_training_images'),
    'Electric Bus': os.path.join(base_dir, 'electric bus'),
    'Electric Car': os.path.join(base_dir, 'electric car'),
    'Human': os.path.join(base_dir, 'human')
}

test_dirs = {
    'Car': os.path.join(base_dir, 'car_testing_images'),
    'Electric Bus': os.path.join(base_dir, 'test electric bus'),
    'Electric Car': os.path.join(base_dir, 'test electric car')
}

# ImageDataGenerators (normalization)
train_datagen = ImageDataGenerator(rescale=1./255)
val_datagen = ImageDataGenerator(rescale=1./255)

# Create unified train and validation directories (for multi-class flow)
# If you have folders separated like train/electric car, train/electric bus — skip this step
# But since yours are split per class, we’ll manually merge them using multiple generators

train_generators = {}
val_generators = {}

for label, path in train_dirs.items():
    if os.path.exists(path):
        train_generators[label] = train_datagen.flow_from_directory(
            directory=os.path.dirname(path),
            classes=[os.path.basename(path)],
            target_size=(150, 150),
            batch_size=20,
            class_mode='categorical',
            shuffle=True
        )

for label, path in test_dirs.items():
    if os.path.exists(path):
        val_generators[label] = val_datagen.flow_from_directory(
            directory=os.path.dirname(path),
            classes=[os.path.basename(path)],
            target_size=(150, 150),
            batch_size=20,
            class_mode='categorical',
            shuffle=True
        )

print("\n✅ Data generators successfully created for:")
print("Train:", list(train_generators.keys()))
print("Validation:", list(val_generators.keys()))

# Our input feature map is 150x150x3: 150x150 for the image pixels, and 3 for # the three color channels: R, G, and B
img_input = layers.Input(shape=(150, 150, 3))
# First convolution extracts 16 filters that are 3x3
# Convolution is followed by max-pooling layer with a 2x2 window
x = layers.Conv2D(16, 3, activation='relu')(img_input)
x = layers.MaxPooling2D(2)(x)
# Second convolution extracts 32 filters that are 3x3
# Convolution is followed by max-pooling layer with a 2x2 window
x = layers.Conv2D(32, 3, activation='relu')(x)
x = layers.MaxPooling2D(2)(x)
# Third convolution extracts 64 filters that are 3x3
# Convolution is followed by max-pooling layer with a 2x2 window
x = layers.Conv2D(64, 3, activation='relu')(x)
x = layers.MaxPooling2D(2)(x)
# Flatten feature map to a 1-dim tensor so we can add fully connected layers x = layers.Flatten()(x)
# Create a fully connected layer with ReLU activation and 512 hidden units x = layers.Dense(512, activation='relu')(x)
# Add a dropout rate of 0.5
x = layers.Dropout(0.5)(x)
# Create output layer with a single node and sigmoid activation
output = layers.Dense(1, activation='sigmoid')(x)
# Create model:
# input = input feature map
# output = input feature map + stacked convolution/maxpooling layers + fully # connected layer + sigmoid output layer
model = Model(img_input, output)
from google.colab import drive
import os
import gc
import tensorflow as tf
from tensorflow.keras import Sequential
from tensorflow.keras.layers import Conv2D, MaxPooling2D, GlobalAveragePooling2D, Dense, Dropout
from tensorflow.keras.optimizers import RMSprop
from tensorflow.keras.preprocessing.image import ImageDataGenerator
from tensorflow.keras.mixed_precision import set_global_policy

# =============================
# GPU Configuration
# =============================
gpus = tf.config.list_physical_devices('GPU')
if gpus:
    try:
        for gpu in gpus:
            tf.config.experimental.set_memory_growth(gpu, True)
        print("✅ GPU Memory Growth Enabled")
    except RuntimeError as e:
        print(e)

# Enable mixed precision
set_global_policy('mixed_float16')

# Cleanup
gc.collect()
tf.keras.backend.clear_session()

# =============================
# Mount Google Drive
# =============================
drive.mount('/content/drive', force_remount=True)

# =============================
# Directories
# =============================
base_dir = '/content/drive/MyDrive/Extracted_Zip/dataset'
train_dir = base_dir  # all class folders directly inside
validation_split = 0.2  # 80/20 split

# =============================
# Strategy for Multi-GPU / Optimization
# =============================
strategy = tf.distribute.MirroredStrategy()
print(f'Number of devices: {strategy.num_replicas_in_sync}')

# =============================
# Model Definition
# =============================
with strategy.scope():
    model = Sequential([
        Conv2D(64, (3, 3), activation='relu', input_shape=(150, 150, 3)),
        MaxPooling2D(2, 2),

        Conv2D(128, (3, 3), activation='relu'),
        MaxPooling2D(2, 2),

        Conv2D(256, (3, 3), activation='relu'),
        MaxPooling2D(2, 2),

        GlobalAveragePooling2D(),
        Dense(256, activation='relu'),
        Dropout(0.3),
        Dense(7, activation='softmax')  # ✅ Matches 7 detected classes
    ])

    model.compile(
        loss='categorical_crossentropy',
        optimizer=RMSprop(learning_rate=0.001),
        metrics=['accuracy']
    )

# =============================
# Data Generators
# =============================
train_datagen = ImageDataGenerator(
    rescale=1./255,
    rotation_range=40,
    width_shift_range=0.2,
    height_shift_range=0.2,
    shear_range=0.2,
    zoom_range=0.2,
    horizontal_flip=True,
    fill_mode='nearest',
    validation_split=validation_split
)

train_generator = train_datagen.flow_from_directory(
    train_dir,
    target_size=(150, 150),
    batch_size=64,
    subset='training',
    class_mode='categorical'
)

validation_generator = train_datagen.flow_from_directory(
    train_dir,
    target_size=(150, 150),
    batch_size=64,
    subset='validation',
    class_mode='categorical'
)

# =============================
# Train the Model
# =============================
history = model.fit(
    train_generator,
    epochs=8,
    validation_data=validation_generator,
    verbose=2,
    shuffle=True
)

# =============================
# Save Model
# =============================
model.save('/content/drive/MyDrive/Extracted_Zip/trained_model_final.h5')
print("\n✅ Training complete! Model saved successfully.")

